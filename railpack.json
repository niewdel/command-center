{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "apt": [
      "chromium",
      "fonts-liberation",
      "libgbm1",
      "libasound2",
      "libatk-bridge2.0-0",
      "libatk1.0-0",
      "libcups2",
      "libdbus-1-3",
      "libdrm2",
      "libnspr4",
      "libnss3",
      "libx11-xcb1",
      "libxcomposite1",
      "libxdamage1",
      "libxrandr2",
      "libxshmfence1",
      "libxkbcommon0"
    ]
  },
  "buildAptPackages": [],
  "variables": {
    "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1",
    "PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH": "/usr/bin/chromium"
  }
}
